{
  "name": "@holo-host/joining-service",
  "version": "0.1.0",
  "description": "Reference joining service for Holochain hApps on Holo",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "source": "./src/client/index.ts",
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen-signing-key": "NODE_OPTIONS=--preserve-symlinks tsx scripts/gen-signing-key.ts"
  },
  "dependencies": {
    "@holo-host/lair": "file:../holo-web-conductor/packages/lair",
    "@hono/node-server": "^1.14.0",
    "@msgpack/msgpack": "^3.0.0",
    "@noble/ed25519": "^2.2.0",
    "@scure/bip39": "^2.0.1",
    "better-sqlite3": "^11.8.0",
    "hono": "^4.7.0",
    "libsodium-wrappers": "^0.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
